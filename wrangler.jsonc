{
  "name": "Nexus",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".open-next/assets",

  // Vars are public — put secrets in Cloudflare dashboard under "Environment Variables"
  // Required secrets: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
  //   SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DATABASE_PASSWORD,
  //   EMAIL_USER, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REFRESH_TOKEN
  "vars": {}
}
